# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT secret — Dashboard → Settings → API → JWT Secret
# Used for local token verification (signature, exp, nbf, iss, aud)
SUPABASE_JWT_SECRET=your-jwt-secret

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=MindVista HRMS

# ─── Email provider (optional — falls back to Supabase built-in if unset) ────
# Set EMAIL_PROVIDER to "brevo" or "resend" to use a custom SMTP provider.
# Free tier: Brevo = 300/day (~9,000/month), Resend = 3,000/month.
# Brevo is recommended for higher volume (3x more free emails).
#
# For Brevo (recommended - 300 emails/day free):
# EMAIL_PROVIDER=brevo
# BREVO_API_KEY=your-brevo-api-key
#
# IMPORTANT: EMAIL_FROM MUST be verified in Brevo dashboard before sending!
# Go to: https://app.brevo.com/settings/senders → Add sender → Verify email
# Unverified senders are silently rejected by Brevo.
#
# For Resend (alternative - 3,000 emails/month free):
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=your-resend-api-key
#
# Required when EMAIL_PROVIDER is set:
# EMAIL_FROM=noreply@yourdomain.com
# EMAIL_FROM_NAME=MindVista HRMS
#
# Diagnostic endpoint (dev only): GET /api/auth/test-brevo?send=true

# ─── Email Validation (optional — prevents fake emails like raju@gmail.com) ──────
# Validates if email addresses actually exist, not just format checking.
# 
# Option 1: AbstractAPI (100 validations/month)
# Get free API key from https://app.abstractapi.com/api/email-validation/pricing
# EMAIL_VALIDATION_API_KEY=your-abstractapi-key
#
# Option 2: MailboxValidator (300 validations/month) - RECOMMENDED
# Get free API key from https://www.mailboxvalidator.com/plans  
# Better free tier with 3x more validations
# MAILBOX_VALIDATOR_API_KEY=your-mailboxvalidator-key
# 
# Benefits:
# - Detects non-existent emails (omar@gmail.com if it doesn't exist)
# - Blocks temporary/disposable emails (10minutemail.com)
# - Identifies role emails (info@, admin@)
# - Quality scoring for suspicious addresses
